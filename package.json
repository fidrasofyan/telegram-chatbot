{
  "name": "telegram-chatbot",
  "version": "0.1.0",
  "module": "src/app.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/app.ts",
    "dev-tools": "bunx --bun @ai-sdk/devtools",
    "code-check-all": "biome check && biome lint && tsc --noEmit",
    "format-check": "biome check",
    "format-fix": "biome check --write",
    "lint-check": "biome lint",
    "type-check": "tsc --noEmit",
    "kysely-codegen": "kysely-codegen --dialect postgres --out-file ./src/database/generated-types.ts",
    "migrate-latest": "bun run ./src/database/migrate.ts latest && bun kysely-codegen",
    "migrate-down": "bun run ./src/database/migrate.ts down && bun kysely-codegen",
    "set-webhook": "bun run set-webhook.ts"
  },
  "dependencies": {
    "@ai-sdk/devtools": "0.0.18",
    "@openrouter/ai-sdk-provider": "2.9.0",
    "ai": "6.0.191",
    "croner": "10.0.1",
    "hono": "4.12.22",
    "kysely": "0.29.2",
    "luxon": "3.7.2",
    "pg": "8.21.0",
    "telegram-markdown-v2": "0.0.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/bun": "1.3.14",
    "@types/luxon": "3.7.1",
    "@types/pg": "8.20.0",
    "kysely-codegen": "0.20.0",
    "typescript": "6.0.3"
  }
}
